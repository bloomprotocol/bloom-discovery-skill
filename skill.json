{
  "name": "bloom-discovery",
  "version": "3.0.0",
  "description": "Discover your builder identity and browse OpenClaw skills. Generates your Bloom Identity Card (Visionary, Explorer, Cultivator, Optimizer, Innovator) with personalized recommendations, and lets you search/browse the skill catalog.",
  "homepage": "https://bloomprotocol.ai",
  "author": "Bloom Protocol",
  "license": "MIT",
  "openclaw": {
    "emoji": "🌸",
    "triggers": [
      "generate my bloom identity",
      "create my identity card",
      "analyze my supporter profile",
      "create my bloom card",
      "discover my personality",
      "show me skills",
      "find skills",
      "search skills",
      "browse skills",
      "recommend skills",
      "what skills are available",
      "skill categories",
      "list categories",
      "what categories"
    ],
    "execution": {
      "type": "script",
      "entrypoint": "scripts/generate.sh",
      "args": ["--user-id", "$OPENCLAW_USER_ID"]
    },
    "requirements": {
      "node": ">=18.0.0",
      "bins": ["node", "npx", "npm"]
    }
  },
  "dependencies": {
    "commander": "^11.1.0",
    "jsonwebtoken": "^9.0.2",
    "viem": "^2.0.0"
  },
  "agentKits": [
    {
      "name": "web3-identity",
      "version": "^2.0.0",
      "source": "npm:viem",
      "required": true,
      "purpose": "EIP-191 signature verification and wallet interactions"
    }
  ],
  "environment": {
    "required": [
      {
        "key": "JWT_SECRET",
        "description": "JWT signing secret for agent authentication",
        "example": "your_secret_key_here"
      },
      {
        "key": "DASHBOARD_URL",
        "description": "Dashboard URL for viewing identity cards",
        "default": "https://preview.bloomprotocol.ai"
      }
    ],
    "optional": [
      {
        "key": "NETWORK",
        "description": "Network for agent wallet: base-mainnet or base-sepolia",
        "default": "base-mainnet"
      }
    ]
  },
  "permissions": {
    "network": [
      "https://api.bloomprotocol.ai",
      "https://api.bloomprotocol.ai/skills",
      "https://api.bloomprotocol.ai/skills/categories",
      "https://api.bloomprotocol.ai/skills/curated-list",
      "https://base-sepolia.blockscout.com",
      "https://base.blockscout.com",
      "https://x402.bloomprotocol.ai"
    ],
    "filesystem": ["read", "write:./data"],
    "execution": ["node", "npx"]
  },
  "installation": {
    "steps": [
      {
        "action": "clone",
        "source": "https://github.com/bloomprotocol/bloom-discovery-skill.git"
      },
      {
        "action": "install_dependencies",
        "command": "npm install"
      },
      {
        "action": "setup_environment",
        "template": ".env.example",
        "target": ".env"
      },
      {
        "action": "verify",
        "command": "npm run test"
      }
    ]
  },
  "status": {
    "endpoint": "/health",
    "ready_check": "scripts/health-check.sh"
  }
}
